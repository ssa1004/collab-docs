{
  "name": "collab-realtime-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Edge WebSocket gateway for collab-docs: authenticates clients (JWT) and relays edit ops / presence to the authoritative Kotlin backend (which performs the OT).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^26.0.0",
    "@types/ws": "^8.5.12",
    "eslint": "^10.5.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.7.0",
    "vitest": "^4.1.9"
  }
}
