# realtime-gateway configuration (copy to .env for local dev; .env is gitignored)

# Port the edge WebSocket + /healthz HTTP server listens on.
PORT=8090

# Shared dev secret for verifying client JWTs (HS256).
# If unset/blank the gateway runs DEV-PERMISSIVE: it accepts unsigned/missing
# tokens and derives a userId from `sub` if present, else "demo-user".
# Set this to enforce real signature verification.
JWT_SECRET=

# Authoritative Kotlin backend WebSocket base URL. The gateway opens one
# upstream connection per client to BACKEND_WS_URL/<documentId>.
# The backend does the OT; the gateway only authenticates, fans out and relays.
BACKEND_WS_URL=ws://localhost:8080/ws/documents

# Optional: log level (debug|info|warn|error). Default: info.
LOG_LEVEL=info

# Optional: when JWT_SECRET is set, reject connections that fail verification
# instead of falling back to permissive mode. Default: true (strict when secret present).
# Set to "false" to always allow dev-permissive fallback even with a secret configured.
JWT_STRICT=true
