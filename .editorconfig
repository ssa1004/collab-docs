root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

[*.{kt,kts}]
indent_size = 4
# ktlint: allow the wildcard imports Spring conventions sometimes use is off by default.
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

[*.{js,ts,mjs,cjs,json,jsonc}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{tpl,gotmpl}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Dockerfile*]
indent_size = 4

[Makefile]
indent_style = tab

[*.sh]
indent_size = 2
